 --- Kernel Specific Hidden Files (IMPORTANT) ---
.*.cmd                # Kernel build command logs (Crucial!)
.tmp_*                # Temporary build directories
.cache.mk             # Build cache files

# --- eBPF Specific ---
bpf/*.ll              # Intermediate LLVM IR files
bpf/*.bc              # Intermediate bitcode files

# --- Mac OS Specific ---
.DS_Store             # Mac system files (Don't let these leak into GitHub!)

# --- Project specific ---
vmlinuz               # Compressed kernel images
rootfs.img            # QEMU rootfs images

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo
